# ==================================================================
# claude-social-media-manager — environment variables
#
# Copy this file to `.env` and fill only the vars you actually use.
# The CLI runs without any of these. CSV export is the default;
# scheduler pushes gracefully no-op without credentials.
# ==================================================================

# -------- Scheduler integrations (all optional) --------
POSTIZ_API_URL=
POSTIZ_API_KEY=
AYRSHARE_API_KEY=
BUFFER_ACCESS_TOKEN=

# -------- CLI / workflow defaults --------
DEFAULT_TIMEZONE=America/Chicago
APPROVAL_REQUIRED=true

# Override DB location (defaults to data/drafts.db)
SMM_DB_PATH=

# -------- NOTES --------
#
# 1. Canonical secrets already live in ~/shared-keys.env.
#    Do NOT duplicate FUB_API_KEY / BEEHIIV_API_KEY / YOUTUBE_API_KEY
#    etc. here. Source them from ~/shared-keys.env and leave this
#    file for SMM-specific scheduler creds only.
#
# 2. This file is gitignored by default (.env is in .gitignore).
#    Never commit a populated .env.
#
# 3. The CLI does NOT auto-load .env. Either:
#      a) export the vars in your shell before running cli.py, or
#      b) `pip install python-dotenv` and prepend
#         `python3 -c "from dotenv import load_dotenv; load_dotenv()"`,
#         or source `.env` in your shell:
#         `set -a; source .env; set +a`
